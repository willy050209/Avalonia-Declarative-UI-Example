<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<TrimMode Condition="'$(Configuration)' != 'Debug'">copyused</TrimMode>
		<BuiltInComInteropSupport>true</BuiltInComInteropSupport>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)' != 'Debug'">
		<PublishAot>true</PublishAot>
	</PropertyGroup>

	<!-- 引用共用核心專案 -->
	<ItemGroup>
		<ProjectReference Include="..\Avalonia Declarative UI Example.Shared\Avalonia Declarative UI Example.Shared.csproj" />
	</ItemGroup>

	<!-- Desktop 專屬套件 -->
	<ItemGroup>
		<PackageReference Include="Avalonia.Desktop" Version="12.0.0" />
		<PackageReference Include="Tmds.DBus.Protocol" Version="0.92.0" />
	</ItemGroup>

	<ItemGroup>
		<TrimmableAssembly Include="Avalonia.Themes.Fluent" />
		<TrimmableAssembly Include="Avalonia.Themes.Default" />
	</ItemGroup>


</Project>
